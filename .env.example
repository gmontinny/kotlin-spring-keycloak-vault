# ========================
# PostgreSQL — Aplicação
# ========================
DB_NAME=olist_db
DB_USERNAME=olist_user
DB_PASSWORD=olist_pass
DB_PORT=5432

# ========================
# PostgreSQL — Keycloak
# ========================
KC_DB_NAME=keycloak_db
KC_DB_USERNAME=keycloak_user
KC_DB_PASSWORD=keycloak_pass
KC_DB_PORT=5433

# ========================
# Keycloak
# ========================
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_PORT=8080

# ========================
# OAuth2 Client
# ========================
KEYCLOAK_CLIENT_ID=olist-client
KEYCLOAK_CLIENT_SECRET=olist-client-secret
KEYCLOAK_REALM=olist-realm
KEYCLOAK_ISSUER_URI=http://localhost:8080/realms/olist-realm

# ========================
# Google OAuth2 (Social Login)
# ========================
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE

# ========================
# Swagger OAuth2 (URLs acessíveis pelo browser)
# ========================
SWAGGER_OAUTH2_AUTH_URL=http://localhost:8080/realms/olist-realm/protocol/openid-connect/auth
SWAGGER_OAUTH2_TOKEN_URL=http://localhost:8080/realms/olist-realm/protocol/openid-connect/token

# ========================
# Aplicação Spring Boot
# ========================
APP_PORT=9090
SPRING_PROFILES_ACTIVE=default

# ========================
# HashiCorp Vault
# ========================
VAULT_TOKEN=vault-root-token
VAULT_PORT=8200
